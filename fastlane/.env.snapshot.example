# Copy this file to fastlane/.env.snapshot (gitignored) and fill in real values.
# Then run:  bundle exec fastlane --env snapshot ios screenshots
#
# The UI test reads these env vars and forwards them as -UITestingServerURL /
# -UITestingToken launch arguments. AuthenticationManager honors them and
# skips the login screen during screenshot runs.

UITESTING_SERVER_URL=https://codeberg.org
UITESTING_TOKEN=paste_demo_account_personal_access_token_here
