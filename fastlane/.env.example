# Copy this file to fastlane/.env (gitignored) and fill in the Issuer ID.
# Used by all metadata/upload lanes (create_app, verify_metadata, upload_metadata).
#
# The .p8 file lives in fastlane/.private/ — the Fastfile auto-discovers it
# by filename (AuthKey_<KEY_ID>.p8) and parses the Key ID from the filename.
# Only the Issuer ID has to be set explicitly; you'll find it on the same
# App Store Connect page where you generated the key.

ASC_API_ISSUER_ID=00000000-0000-0000-0000-000000000000
